# syntax=docker/dockerfile:1
FROM alpine:3.21

# GOOD: BuildKit secret mount — available only during this RUN, never stored in any layer
# The secret is mounted at /run/secrets/<id> and vanishes after the RUN completes
RUN --mount=type=secret,id=db_password \
    --mount=type=secret,id=api_key \
    DB_PASSWORD=$(cat /run/secrets/db_password) \
    && API_KEY=$(cat /run/secrets/api_key) \
    && echo "app configured" > /app.txt

CMD ["cat", "/app.txt"]
